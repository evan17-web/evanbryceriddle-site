---
import { Image } from 'astro:assets';
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import Icon from './Icon.astro';
import cover from '../assets/book-cover.jpg';

const { book } = site;
---
<section class="section section--raised" id="book">
  <div class="container book reveal">
    <div class="book__cover">
      <Image
        src={cover}
        alt={book.coverAlt}
        widths={[300, 340, 680]}
        sizes="(max-width: 800px) 55vw, 340px"
        format="webp"
        quality={80}
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="book__body">
      <h2 set:html={emphasize(book.heading)} />
      <p>{book.body}</p>
      <div class="book__actions">
        <a class="btn btn--accent" href={book.cta.href} target="_blank" rel="noopener noreferrer">
          {book.cta.label}
          <Icon name="arrow-up-right" size={18} />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .book { display: grid; gap: 2.5rem; align-items: center; }
  @media (min-width: 800px) {
    .book { grid-template-columns: auto 1fr; gap: clamp(2.5rem, 5vw, 4.5rem); }
  }

  .book__cover { display: flex; justify-content: center; }
  .book__cover :global(img) {
    width: 100%;
    max-width: 340px;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 18px 40px rgba(26, 22, 12, 0.2);
  }

  .book__body { max-width: 46ch; }
  .book__body p { margin-top: 1rem; color: var(--ink-soft); font-size: 1.1rem; }
  .book__actions { margin-top: 1.75rem; }
</style>
