---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import Icon from './Icon.astro';

const { hero } = site;
---
<section class="section hero">
  <div class="container hero__inner">
    <div class="hero__text">
      <p class="eyebrow hero__kicker">{hero.kicker}</p>
      <h1 class="hero__headline" set:html={emphasize(hero.headline)} />
      <p class="lead hero__subhead">{hero.subhead}</p>
      <div class="hero__actions">
        <a class="btn btn--accent" href={hero.primary.href} target="_blank" rel="noopener noreferrer">
          {hero.primary.label}
          <Icon name="arrow-up-right" size={18} />
        </a>
        <a class="btn btn--secondary" href={hero.secondary.href}>
          <Icon name="mail" size={18} />
          {hero.secondary.label}
        </a>
      </div>
      <p class="currently hero__currently"><b>Currently</b> — {hero.currently}</p>
    </div>

    <div class="hero__aside">
      <figure class="portrait">
        {hero.photo ? (
          <img
            class="portrait__img"
            src={hero.photo}
            alt={hero.photoAlt}
            width="640"
            height="800"
            loading="eager"
          />
        ) : (
          <div class="portrait__ph">
            <span class="portrait__mono">EBR</span>
            <span class="portrait__sig signature">Evan</span>
          </div>
        )}
      </figure>
    </div>
  </div>
</section>

<style>
  .hero { padding-block: clamp(2.25rem, 1rem + 6vw, 5rem) clamp(3.5rem, 2rem + 7vw, 6rem); }
  .hero__inner { display: grid; gap: clamp(2.5rem, 5vw, 4rem); align-items: center; }
  @media (min-width: 880px) {
    .hero__inner { grid-template-columns: 1.15fr 0.85fr; }
  }

  .hero__kicker { margin-bottom: 1.2rem; }
  .hero__headline { max-width: 16ch; font-size: clamp(2.6rem, 1.1rem + 6.2vw, 4.6rem); }
  .hero__subhead { margin-top: 1.4rem; max-width: 42ch; }
  .hero__actions { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.85rem; }
  .hero__currently { margin-top: 1.6rem; }

  /* Portrait */
  .hero__aside { display: flex; justify-content: center; }
  .portrait {
    position: relative;
    width: 100%;
    max-width: min(360px, 74vw);
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper-raised);
    border: 1px solid var(--line-strong);
    box-shadow: var(--shadow);
    transform: rotate(1.2deg);
  }
  .portrait__img { width: 100%; height: 100%; object-fit: cover; }
  .portrait__ph {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    background:
      radial-gradient(115% 85% at 50% 0%, rgba(176, 85, 46, 0.09), transparent 62%),
      var(--paper-raised);
  }
  .portrait__mono {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 3.2rem;
    letter-spacing: 0.05em;
    color: var(--line-strong);
  }
  .portrait__sig { font-size: 2.5rem; color: var(--accent-text); transform: rotate(-3deg); }

  @media (max-width: 460px) {
    .hero__actions { flex-direction: column; align-items: stretch; }
  }
</style>
