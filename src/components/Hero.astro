---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import Icon from './Icon.astro';

const { hero } = site;
---
<section class="section hero">
  <div class="container">
    <p class="eyebrow hero__kicker">{hero.kicker}</p>
    <h1 class="hero__headline" set:html={emphasize(hero.headline)} />
    <p class="lead hero__subhead">{hero.subhead}</p>
    <div class="hero__actions">
      <a class="btn btn--gold" href={hero.primary.href} target="_blank" rel="noopener noreferrer">
        {hero.primary.label}
        <Icon name="arrow-up-right" size={18} />
      </a>
      <a class="btn btn--secondary" href={hero.secondary.href}>
        <Icon name="mail" size={18} />
        {hero.secondary.label}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 1rem + 9vw, 7rem) clamp(3.5rem, 2rem + 7vw, 6rem);
  }
  .hero__kicker { margin-bottom: 1.2rem; }
  .hero__headline {
    max-width: 20ch;
    font-size: clamp(2.55rem, 1.4rem + 5.3vw, 4.4rem);
  }
  .hero__subhead {
    margin-top: 1.6rem;
    max-width: 46ch;
  }
  .hero__actions {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  @media (max-width: 460px) {
    .hero__actions { flex-direction: column; align-items: stretch; }
  }
</style>
