---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import Icon from './Icon.astro';
import VideoFacade from './VideoFacade.astro';

const { about } = site;
---
<section class="section section--raised" id="about">
  <div class="container about reveal">
    <div class="about__intro">
      <p class="eyebrow eyebrow--teal">{about.eyebrow}</p>
      <h2 class="about__heading" set:html={emphasize(about.heading)} />
      <div class="about__lead">
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <ul class="chip-row about__values">
        {about.values.map((value) => <li class="chip">{value}</li>)}
      </ul>
      <blockquote class="pullquote about__quote">{about.pullquote}</blockquote>
      <p class="signature about__sign">{about.signoff}</p>
    </div>

    <div class="about__media">
      <div class="about__video">
        <p class="about__media-label">
          <Icon name="play-circle" size={16} /> Rather hear it from me?
        </p>
        <ul class="about__video-list">
          <VideoFacade id={about.featuredVideo.id} title={about.featuredVideo.title} />
        </ul>
      </div>
      {about.photos.map((photo) => (
        <figure class="about__photo">
          {photo.src ? (
            <img src={photo.src} alt={photo.label} loading="lazy" decoding="async" />
          ) : (
            <div class="media-ph">
              <Icon name="image" size={26} />
              <span>{photo.label}</span>
            </div>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .about { display: grid; gap: 2.75rem; }
  @media (min-width: 900px) {
    .about { grid-template-columns: 1.05fr 0.95fr; gap: 1.5rem 4rem; align-items: start; }
  }

  .about__heading { margin-top: 0.85rem; max-width: 14ch; }
  .about__lead { margin-top: 1.4rem; display: flex; flex-direction: column; gap: 1.05rem; }
  .about__lead p { color: var(--ink-soft); font-size: 1.1rem; }
  .about__values { margin-top: 1.6rem; }
  .about__quote {
    margin-top: 1.85rem;
    max-width: 30ch;
    padding-left: 1.25rem;
    border-left: 3px solid var(--teal);
  }
  p.about__sign { margin-top: 1rem; font-size: 2.9rem; line-height: 1; }

  .about__media { display: flex; flex-direction: column; gap: 1.4rem; }
  .about__media-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.7rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--teal-text);
  }
  .about__video-list { display: block; }
  .about__photo { aspect-ratio: 4 / 3; }
  .about__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
</style>
