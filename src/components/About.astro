---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';

const { about } = site;
---
<section class="section section--raised" id="about">
  <div class="container about reveal">
    <div class="about__intro">
      <h2 class="about__heading" set:html={emphasize(about.heading)} />
      <blockquote class="pullquote about__quote">{about.pullquote}</blockquote>
    </div>
    <div class="about__body">
      {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <p class="signature about__sign">{about.signoff}</p>
    </div>
  </div>
</section>

<style>
  .about { display: grid; gap: 2.25rem; }
  @media (min-width: 880px) {
    .about { grid-template-columns: 0.9fr 1.1fr; gap: 1.5rem 4rem; align-items: start; }
  }
  .about__heading { max-width: 11ch; }
  .about__quote { margin-top: 1.5rem; max-width: 26ch; }
  .about__body {
    max-width: var(--maxw-prose);
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }
  .about__body p { color: var(--ink-soft); font-size: 1.1rem; }
  p.about__sign { margin-top: 0.6rem; font-size: 2.9rem; line-height: 1; }
</style>
