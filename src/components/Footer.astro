---
import { site } from '../content/site';
import Icon from './Icon.astro';
import { withUtm } from '../lib/url.mjs';

const socials = [
  { name: 'LinkedIn', href: site.social.linkedin, icon: 'linkedin' as const },
  { name: 'Instagram', href: site.social.instagram, icon: 'instagram' as const },
  { name: 'YouTube', href: site.social.youtube, icon: 'youtube' as const },
];
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="#top" class="footer__name signature">{site.name}</a>
      <p class="footer__tag">{site.hero.kicker}</p>
    </div>

    <div class="footer__right">
      <a class="footer__contact" href={`mailto:${site.contactEmail}`}>
        <Icon name="mail" size={18} />
        <span>{site.contactEmail}</span>
      </a>
      <ul class="footer__social">
        {socials.map((s) => (
          <li>
            <a href={withUtm(s.href, 'footer-' + s.icon)} aria-label={s.name} target="_blank" rel="noopener noreferrer">
              <Icon name={s.icon} size={20} />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="container">
    <a class="oldsite" href={withUtm(site.oldSite.url, 'footer-old-site')} target="_blank" rel="noopener noreferrer">
      <span class="oldsite__bar">
        <span class="oldsite__dots"><i></i><i></i><i></i></span>
        <span class="oldsite__title">Previously</span>
      </span>
      <span class="oldsite__body">
        <span class="oldsite__text">{site.oldSite.label}</span>
        <span class="oldsite__cta">Visit the old site <Icon name="arrow-up-right" size={15} /></span>
      </span>
    </a>
  </div>

  <div class="container footer__base">
    <p>{site.copyright}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--paper-raised);
    padding-block: clamp(2.75rem, 6vw, 3.75rem) 1.75rem;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.75rem 1.5rem;
  }
  .footer__name {
    font-family: var(--font-script);
    font-size: 2.3rem;
    line-height: 1;
    color: var(--ink);
    transition: color 0.18s ease;
  }
  .footer__name:hover { color: var(--accent-text); }
  .footer__tag {
    margin-top: 0.6rem;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
  }

  .footer__right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.1rem;
  }
  .footer__contact {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--ink-soft);
    transition: color 0.18s ease;
  }
  .footer__contact:hover { color: var(--accent-text); }

  .footer__social { display: flex; gap: 0.6rem; }
  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    background: var(--card);
    transition: color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
  }
  .footer__social a:hover {
    color: var(--ink);
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }

  .footer__base {
    margin-top: clamp(2rem, 5vw, 3rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .footer__base p { font-size: 0.85rem; color: var(--ink-faint); }

  .oldsite {
    display: block;
    margin: clamp(2.25rem, 5vw, 3.25rem) auto 0;
    max-width: 40rem;
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: 12px;
    box-shadow: 5px 5px 0 0 var(--ink);
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .oldsite:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 0 var(--teal); }
  .oldsite__bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.95rem;
    background: var(--ink);
  }
  .oldsite__dots { display: inline-flex; gap: 0.42rem; }
  .oldsite__dots i {
    display: block;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
  }
  .oldsite__dots i:nth-child(1) { background: #d8613f; }
  .oldsite__dots i:nth-child(2) { background: #e3a73f; }
  .oldsite__dots i:nth-child(3) { background: var(--teal); }
  .oldsite__title {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 241, 232, 0.72);
  }
  .oldsite__body {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem 1.5rem;
    padding: 1.25rem 1.4rem;
  }
  .oldsite__text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.4;
    color: var(--ink-soft);
    max-width: 42ch;
  }
  .oldsite__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--ink);
    white-space: nowrap;
    box-shadow: inset 0 -2px 0 0 var(--teal);
    transition: color 0.18s ease, box-shadow 0.18s ease;
  }
  .oldsite:hover .oldsite__cta { color: var(--teal-text); box-shadow: inset 0 -0.7em 0 0 rgba(19, 138, 144, 0.16); }

  @media (min-width: 620px) {
    .footer__right { align-items: flex-end; }
  }
</style>
