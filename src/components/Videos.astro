---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import { getVideos } from '../lib/youtube.mjs';
import Icon from './Icon.astro';
import VideoFacade from './VideoFacade.astro';

const cfg = site.videos;

// Build-time fetch: pulls the newest uploads (or the manual fallback list).
const { videos } = await getVideos({
  mode: cfg.mode,
  channelId: cfg.channelId,
  count: cfg.count,
  fallbackIds: cfg.fallbackIds,
});
---
<section class="section section--raised" id="videos">
  <div class="container">
    <div class="videos__head reveal">
      <div class="section-head">
        <h2 set:html={emphasize(cfg.heading)} />
        <p>{cfg.body}</p>
      </div>
      <a class="btn btn--secondary videos__channel" href={cfg.channelUrl} target="_blank" rel="noopener noreferrer">
        <Icon name="youtube" size={18} />
        Visit the channel
      </a>
    </div>

    <ul class="video-grid">
      {videos.map((video) => <VideoFacade id={video.id} title={video.title} />)}
    </ul>
  </div>
</section>

<style>
  .videos__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem 1.5rem;
  }
  .videos__channel { flex: none; }

  .video-grid {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 1.15rem;
  }
  @media (min-width: 560px) {
    .video-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 880px) {
    .video-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<script>
  // Click-to-load facade: swap the thumbnail for the real player on click.
  // autoplay=1 is intentional here — the load is user-initiated, so the play
  // registers as a genuine YouTube view (this is NOT autoplay on page load).
  function buildPlayer(id: string, title: string): HTMLIFrameElement {
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
    iframe.title = title || 'YouTube video player';
    iframe.allow =
      'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.setAttribute('allowfullscreen', '');
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
    return iframe;
  }

  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    const btn = target?.closest?.('.video__btn');
    if (!btn) return;
    event.preventDefault();
    const frame = btn.closest('.video__frame');
    const id = btn.getAttribute('data-id');
    if (!frame || !id) return;
    frame.replaceChildren(buildPlayer(id, btn.getAttribute('data-title') ?? ''));
  });
</script>
