---
import { site } from '../content/site';
import { emphasize } from '../lib/text.mjs';
import { getVideos, fetchLongFormViaApi } from '../lib/youtube.mjs';
import Icon from './Icon.astro';
import VideoFacade from './VideoFacade.astro';
import { withUtm } from '../lib/url.mjs';

const cfg = site.videos;
const apiKey = process.env.YOUTUBE_API_KEY;

// With a YouTube Data API key, auto-fetch the newest LONG-FORM uploads (Shorts
// filtered out by duration). Without a key, use the curated list (or RSS).
let videos;
if (apiKey) {
  try {
    videos = await fetchLongFormViaApi({
      apiKey,
      channelId: cfg.channelId,
      count: cfg.count,
      minDurationSeconds: cfg.minDurationSeconds,
    });
  } catch (err) {
    console.warn('[videos] Data API fetch failed, using curated list:', err instanceof Error ? err.message : err);
    videos = cfg.longform.slice(0, cfg.count);
  }
} else if (cfg.mode === 'manual') {
  videos = cfg.longform.slice(0, cfg.count);
} else {
  const result = await getVideos({
    mode: 'rss',
    channelId: cfg.channelId,
    count: cfg.count,
    fallbackIds: cfg.longform.map((v) => v.id),
  });
  videos = result.videos;
}
---
<section class="section section--raised" id="videos">
  <div class="container">
    <div class="videos__head reveal">
      <div class="section-head">
        <h2 set:html={emphasize(cfg.heading)} />
        <p class="videos__why">{cfg.body}</p>
      </div>
      <a class="btn btn--secondary videos__channel" href={withUtm(`https://www.youtube.com/channel/${cfg.channelId}?sub_confirmation=1`, 'videos-subscribe')} target="_blank" rel="noopener noreferrer">
        <Icon name="youtube" size={18} />
        Visit the channel
      </a>
    </div>

    <ul class="video-grid">
      {videos.map((video) => <VideoFacade id={video.id} title={video.title} />)}
    </ul>
  </div>
</section>

<style>
  .videos__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.25rem 1.5rem;
  }
  .videos__channel { flex: none; }

  /* the "why I document the journey" lead */
  .videos__why {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 1rem + 1vw, 1.55rem);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 40ch;
  }

  .video-grid {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.85rem 1.6rem;
  }
  @media (min-width: 640px) {
    .video-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  // Click-to-load facade: swap the thumbnail for the real player on click.
  // autoplay=1 is intentional here — the load is user-initiated, so the play
  // registers as a genuine YouTube view (this is NOT autoplay on page load).
  function buildPlayer(id: string, title: string): HTMLIFrameElement {
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0&playsinline=1`;
    iframe.title = title || 'YouTube video player';
    iframe.allow =
      'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.setAttribute('allowfullscreen', '');
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
    return iframe;
  }

  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    const btn = target?.closest?.('.video__btn');
    if (!btn) return;
    event.preventDefault();
    const frame = btn.closest('.video__frame');
    const id = btn.getAttribute('data-id');
    if (!frame || !id) return;
    const player = buildPlayer(id, btn.getAttribute('data-title') ?? '');
    frame.replaceChildren(player);
    player.focus(); // keep keyboard focus on the player the user just opened
  });
</script>
